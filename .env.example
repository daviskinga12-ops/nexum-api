# ═══════════════════════════════════════════════════
# NEXUM API — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# M-Pesa Daraja API (Safaricom)
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_CALLBACK_URL=https://nexum-api.up.railway.app/api/v1/mpesa/callback
MPESA_ENV=sandbox
# Set MPESA_ENV=production when going live

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS - comma separated allowed origins
ALLOWED_ORIGINS=https://nexum.vercel.app,http://localhost:3000
